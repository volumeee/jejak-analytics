# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://jejak:jejak_secret@localhost:5432/jejak_analytics
POSTGRES_USER=jejak
POSTGRES_PASSWORD=jejak_secret
POSTGRES_DB=jejak_analytics

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────
PORT=3100
NODE_ENV=development
CORS_ORIGIN=http://localhost:3101
JWT_SECRET=change-me-to-a-random-secret-key-minimum-32-chars

# ── Dashboard ─────────────────────────────────────
VITE_API_URL=http://localhost:3100
VITE_WS_URL=ws://localhost:3100

# ── Admin (created on first startup) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Data Retention (days, 0 = keep forever) ───────
RETENTION_PAGE_VIEWS=365
RETENTION_SESSIONS=365
RETENTION_RECORDINGS=30
RETENTION_HEATMAPS=90
RETENTION_ERRORS=90
